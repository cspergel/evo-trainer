# Evolve-Trader AI — Environment Variables
# Copy to .env and fill in values. .env is gitignored.

# LLM providers (at least one required for Phase 1+)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Alpaca brokerage (Phase 6+)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Database (Phase 2+ — Docker Compose sets this automatically for local dev)
# DATABASE_URL=postgresql://evolve_trader:dev_password@localhost:5434/evolve_trader
